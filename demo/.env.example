# Copy to demo/.env and fill in. Used by demo/docker-compose.yml.

# REQUIRED — the secret every demo app's proxy_secret is derived from (HMAC).
# Any random string >= 16 chars. Generate one with: openssl rand -hex 24
DEMO_SECRET=

# Minutes from the first sign-in (after each reset) until the DB auto-resets.
DEMO_LIMIT_MINS=10

# External base URL the portal is reached on. Local: http://localhost.
# On Coolify: your demo's https URL (also set this as the traefik service's domain).
PORTAL_BASE_URL=http://localhost

# Set true when PORTAL_BASE_URL is https (Coolify). Local http must stay false,
# or the session cookie is dropped.
COOKIE_SECURE=false

# Host port Traefik listens on locally (the whole demo entrypoint).
DEMO_HTTP_PORT=80

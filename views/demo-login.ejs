<%- include('partials/head', { title: t('demo.loginTitle'), user: null, isAdmin: false }) %>

<h1><%= t('demo.loginTitle') %></h1>
<p class="muted"><%= t('demo.loginIntro') %></p>

<div class="grid">
  <% personas.forEach(function (p) { %>
    <div class="card">
      <div><strong><%= p.name %></strong></div>
      <div class="desc"><code><%= p.email %></code></div>
      <div class="desc"><%= t('demo.rolesLabel') %>: <%= p.roles.join(', ') %></div>
      <div class="desc"><%= t('demo.persona.' + p.key) %></div>
      <form method="post" action="/demo/login" style="margin-top:10px">
        <input type="hidden" name="email" value="<%= p.email %>" />
        <input type="hidden" name="next" value="<%= next %>" />
        <button type="submit" class="btn primary"><%= t('demo.signInAs', { name: p.name }) %></button>
      </form>
    </div>
  <% }) %>
</div>

<%- include('partials/foot') %>

<%- include('../partials/head', { title: t('users.title'), user, isAdmin }) %>

<div class="page-head">
  <h1><%= t('users.title') %></h1>
  <a class="btn primary" href="/admin/users/new"><%= t('users.newUser') %></a>
</div>
<div class="page-actions">
  <a class="btn" href="/admin/users/import"><%= t('usersImport.importBtn') %></a>
</div>
<% if (typeof managementConfigured !== 'undefined' && !managementConfigured) { %>
  <div class="card" style="border-color:#f59e0b;"><%= t('users.mgmtWarning') %></div>
<% } %>

<form class="search-form" method="get" action="/admin/users">
  <input name="q" value="<%= q %>" placeholder="<%= t('users.searchPlaceholder') %>" />
  <button type="submit" class="primary" aria-label="<%= t('common.search') %>">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>
    <span><%= t('common.search') %></span>
  </button>
</form>

<div class="table-scroll">
<table>
  <thead><tr><th><%= t('users.colEmail') %></th><th><%= t('users.colName') %></th><th><%= t('users.colStatus') %></th><th><%= t('users.colRoles') %></th><th><%= t('users.colLastLogin') %></th></tr></thead>
  <tbody>
    <% users.forEach(function(u){ %>
      <tr>
        <td><a href="/admin/users/<%= u._id %>"><%= u.email %></a></td>
        <td><%= u.name || '' %></td>
        <td><%= t('common.status.' + u.status) %></td>
        <td><%= (u.roles||[]).join(', ') %></td>
        <td><%= fmtTime(u.last_login_at) %></td>
      </tr>
    <% }) %>
    <% if (users.length === 0) { %><tr><td colspan="5" class="muted"><%= t('users.empty') %></td></tr><% } %>
  </tbody>
</table>
</div>

<%- include('../partials/foot') %>

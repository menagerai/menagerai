<%- include('partials/head', { title: 'Set up ' + brand, user: null, isAdmin: false }) %>

<div class="card">
  <h1>Welcome to <%= brand %></h1>
  <p class="muted">A one-time setup to connect your identity provider and create the first administrator.
    <%= brand %> never stores passwords — sign-in is delegated to your IdP.</p>

  <% if (error) { %>
    <p class="toast error" style="position:static;box-shadow:none;margin:12px 0;"><%= error %></p>
  <% } %>

  <ol class="muted" style="margin:14px 0;">
    <li<%= step === 'provider' ? ' style="color:var(--fg);font-weight:600"' : '' %>>1. Identity provider</li>
    <li<%= step === 'superadmin' ? ' style="color:var(--fg);font-weight:600"' : '' %>>2. Administrator</li>
    <li<%= step === 'finish' ? ' style="color:var(--fg);font-weight:600"' : '' %>>3. Sign in to finish</li>
  </ol>

  <% if (step === 'provider') { %>
    <h2>1. Connect <%= providerName %></h2>
    <% if (!encryptionAvailable) { %>
      <p>To save provider secrets in the app, set an <code>APP_ENCRYPTION_KEY</code> environment
         variable (any long random string) and restart, then reload this page. Alternatively, set the
         <code>LOGTO_ENDPOINT</code> / <code>LOGTO_APP_ID</code> / <code>LOGTO_APP_SECRET</code> env
         vars directly and restart.</p>
    <% } else { %>
      <p class="muted">Create a Traditional Web app in your Logto console, add
        <code><%= '/callback' %></code> redirect URIs for your host(s), then paste its keys here.</p>
      <form method="post" action="/setup/provider">
        <p><label>Logto endpoint<br><input name="endpoint" style="width:100%" placeholder="https://your-tenant.logto.app" required></label></p>
        <p><label>App ID<br><input name="appId" style="width:100%" required></label></p>
        <p><label>App secret<br><input name="appSecret" type="password" style="width:100%" required></label></p>
        <p><label>Scopes <span class="muted">(optional)</span><br><input name="scopes" style="width:100%" placeholder="openid profile email"></label></p>
        <details>
          <summary class="muted">Management API (optional — enables creating/suspending users in Logto)</summary>
          <p><label>M2M App ID<br><input name="m2mAppId" style="width:100%"></label></p>
          <p><label>M2M App secret<br><input name="m2mAppSecret" type="password" style="width:100%"></label></p>
          <p><label>Management API resource<br><input name="managementResource" style="width:100%" placeholder="https://<tenant-id>.logto.app/api"></label></p>
        </details>
        <p><button class="btn primary" type="submit">Save &amp; continue</button></p>
      </form>
    <% } %>

  <% } else if (step === 'superadmin') { %>
    <h2>2. Create the administrator</h2>
    <p>Provider connected<% if (envProvider) { %> (via environment variables)<% } %>.
       The first administrator will be the account that signs in with:</p>
    <p><strong><%= superadminEmail %></strong>
       <span class="muted">— set <code>SUPERADMIN_EMAIL</code> to change this.</span></p>
    <p class="muted">Make sure a user with this email exists in <%= providerName %>.</p>
    <form method="post" action="/setup/superadmin">
      <button class="btn primary" type="submit">Create administrator &amp; continue</button>
    </form>

  <% } else { %>
    <h2>3. Sign in to finish</h2>
    <p>Everything is ready. Sign in as <strong><%= superadminEmail %></strong> to claim the
       administrator account and complete setup.</p>
    <p><a class="btn primary" href="/login">Sign in with <%= providerName %></a></p>
  <% } %>
</div>

<%- include('partials/foot') %>

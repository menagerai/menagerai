# ---- Core ----
PORT=3000
# REQUIRED. Canonical external base URL of the portal (no trailing slash). Also
# determines the OIDC redirect URI — register ${PORTAL_BASE_URL}/callback in your
# Logto app. Local dev: http://localhost:3000
PORTAL_BASE_URL=https://portal.example.com

# Additional interchangeable hostnames this single portal answers on (comma-
# separated, no scheme). The PORTAL_BASE_URL host is always included. Only these
# hosts are honored when building redirects (host-injection defense). Register a
# /callback for EACH of them in Logto.
PORTAL_HOSTS=app.example.com

# Domains an app's "Default URL" may be set to (comma-separated, no scheme).
# Optional per-app: on the app's admin page, pick one of these instead of
# "unset" to make its launcher link an absolute URL on that domain rather than
# a path relative to whichever portal host the user is on.
DEFAULT_BASE_URLS=app1.example.com,app2.example.com

# ---- Data store ----
# SQLite is the primary/default backend: a single file. Put it on a persistent
# volume so data survives redeploys (e.g. mount a volume at /app/data). Created
# automatically on first run.
SQLITE_PATH=./data/menagerai.db

# Optional: set a MongoDB connection string to use MongoDB INSTEAD of SQLite
# (the pluggable secondary backend). When set, SQLITE_PATH is ignored.
# MONGODB_CONN_STR=mongodb://user:pass@host:27017/
# MONGODB_DB=menagerai

# ---- Sessions ----
SESSION_COOKIE_NAME=menagerai_session
SESSION_IDLE_SECONDS=28800
SESSION_ABSOLUTE_SECONDS=604800
# Set to false ONLY for local http development.
COOKIE_SECURE=true

# ---- Identity provider (Logto) — REQUIRED ----
# Menagerai delegates authentication to Logto. All six LOGTO_* values below are
# REQUIRED: the app still boots without them, but it serves a configuration screen
# (and seeds nothing) until every one is set and the Logto endpoints actually
# respond. See the README Quickstart for how to obtain them.
#
# From the OIDC application you create in Logto for the portal:
LOGTO_ENDPOINT=https://your-tenant.logto.app
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_SCOPES=openid profile email
# ID-token signing alg. Logto signs with ES384 by default (this is the app default);
# override only if your tenant signs differently.
LOGTO_ID_TOKEN_ALG=ES384

# From the Machine-to-Machine application you create in Logto and grant the
# "Logto Management API access" role. This lets Menagerai provision users into
# Logto when you add them in the portal — so you never create Logto accounts by
# hand. The resource indicator is the Management API URL, e.g.
# https://your-tenant.logto.app/api (shown on Logto's Management API details page).
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=
LOGTO_MANAGEMENT_API_RESOURCE=https://your-tenant.logto.app/api

# ---- Bootstrap (REQUIRED) ----
# The first admin. On the first valid startup this identity is seeded (an allow-rule
# + the system_admin role + an unlinked user row) and claimed on first sign-in — so
# it MUST also exist as an account in your Logto (create it there, or enable Logto
# self-registration for this address).
SUPERADMIN_EMAIL=you@yourcompany.com

# ---- Tuning ----
DECISION_CACHE_TTL_MS=30000

# ---- Usage statistics ----
# IANA timezone defining the business-day boundary for DAU counting (one active
# day per user per app). Leave unset to inherit the container's own TZ env (if
# set), otherwise UTC. Set explicitly to pin a zone, e.g. America/New_York.
# TIMEZONE=UTC
# Rows shown in the per-user "most used apps" and per-app "power users" tables.
USAGE_TOP_LIMIT=10
# Trailing window (days) covered by the activity heatmap.
USAGE_HEATMAP_DAYS=365
# Cards per dashboard list (Top apps / Top users), ranked by recent activity.
DASHBOARD_TOP_LIMIT=6

# ---- Debugging ----
# Set to 1 to log every /gateway/verify decision (method, URI, nav/api, user,
# outcome+reason). Off by default (noise/PII). Turn on temporarily when
# diagnosing redirect loops or 401/403s on a gated app. If a request to a gated
# app produces NO line here, ForwardAuth isn't wired to that app's router.
GATEWAY_LOG=0

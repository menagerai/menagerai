{
  "name": "menagerai",
  "version": "0.1.0",
  "description": "Menagerai — one login, per-app access control, and usage analytics for the apps you deploy",
  "license": "AGPL-3.0-only",
  "private": true,
  "main": "dist/server-all.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server-all.js",
    "start:web": "node dist/server-web.js",
    "start:gateway": "node dist/server-gateway.js",
    "seed": "node dist/seed.js",
    "relink": "node dist/relink.js",
    "dev": "tsx watch src/server-all.ts",
    "dev:seed": "tsx src/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "better-sqlite3": "^11.10.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.1",
    "mongodb": "^6.10.0",
    "multer": "^2.2.0",
    "openid-client": "^5.7.0",
    "swagger-ui-dist": "^5.32.8",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.5",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-dist": "^3.30.6",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
